# Environment Configuration Template
# Copy to .env and fill in your values
# .env will be ignored by git (see .gitignore)

# Project Settings
PROJECT_NAME=geothermal-piles-pinn
DEBUG=True
SEED=42

# Data Paths
DATA_RAW_PATH=data/raw/
DATA_PROCESSED_PATH=data/processed/
MODELS_PATH=models/saved/
RESULTS_PATH=results/

# Training Parameters
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=1000
VALIDATION_SPLIT=0.2

# GPU/Computing
USE_GPU=True
GPU_ID=0
NUM_WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs/

# Database (if needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=pinn_db
# DB_USER=user
# DB_PASSWORD=password

# API Keys (if needed)
# WANDB_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
